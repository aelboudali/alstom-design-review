                    <Unity.AppUI.UI.Text name="AssetName" size="XL" class="ivt-font-semi-bold" style="-unity-text-align: middle-left; border-left-color: rgb(255, 255, 255); flex-shrink: 1; font-size: 18px; color: rgb(188, 188, 188); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; height: 24px; flex-grow: 0; margin-right: 4px;"/>
                    <Unity.AppUI.UI.Text name="VerBox" text="Ver.1" class="ivt-font-semi-bold" style="height: 20px; border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px; border-top-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-left-width: 1px; border-left-color: rgb(63, 63, 63); border-right-color: rgb(63, 63, 63); border-top-color: rgb(63, 63, 63); border-bottom-color: rgb(63, 63, 63); margin-top: 1px; padding-right: 4px; padding-left: 4px; font-size: 12px; -unity-text-align: middle-center; min-width: 41px;"/>
                </ui:VisualElement>
                <Unity.AppUI.UI.Text name="AssetType" size="M" text="3D Model" style="-unity-text-align: middle-center; flex-shrink: 1; font-size: 14px; color: rgb(255, 255, 255); width: 106px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; height: 24px; background-color: rgb(72, 72, 72); border-top-left-radius: 12px; border-top-right-radius: 12px; border-bottom-right-radius: 12px; border-bottom-left-radius: 12px;"/>
            </ui:VisualElement>
            <Unity.AppUI.UI.Tabs name="Tabs" size="L" value="0" style="height: 48px; min-height: 48px; justify-content: space-around;">
