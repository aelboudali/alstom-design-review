<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/Features/Assets/UI/AssetInfoPanelStyle.uss?fileID=7433441132597879392&amp;guid=126bdc3edb96449bb8e4d2bd02c1c2fc&amp;type=3#AssetInfoPanelStyle"/>
    <ui:VisualElement name="AssetInfoPanelRoot" picking-mode="Ignore" style="align-items: stretch; justify-content: flex-start; width: 535px; height: 811px; flex-grow: 1;">
        <ui:VisualElement name="AssetInfoPanelTop" style="flex-direction: row; border-bottom-width: 1px; border-left-color: rgb(48, 48, 48); border-right-color: rgb(48, 48, 48); border-top-color: rgb(48, 48, 48); border-bottom-color: rgb(48, 48, 48); justify-content: space-between; height: 56px; min-height: 56px; max-height: 56px;">
            <Unity.AppUI.UI.IconButton name="CloseButton" size="L" icon="x" style="width: 40px; height: 40px;"/>
        </ui:VisualElement>
        <ui:VisualElement style="flex-grow: 1;">
            <ui:VisualElement style="flex-direction: row; justify-content: space-between; margin-top: 12px; margin-right: 12px; margin-bottom: 18px; margin-left: 12px;">
