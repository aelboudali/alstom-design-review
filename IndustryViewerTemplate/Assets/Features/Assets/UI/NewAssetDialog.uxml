    <engine:VisualElement name="NewAssetPanel" focusable="false" style="width: 588px; height: 700px; background-color: rgb(29, 29, 29); border-left-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); border-top-color: rgb(255, 255, 255); border-bottom-color: rgb(255, 255, 255); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; border-top-left-radius: 12px; border-top-right-radius: 12px; border-bottom-right-radius: 12px; border-bottom-left-radius: 12px; justify-content: space-around; flex-direction: column; padding-top: 12px; padding-right: 12px; padding-bottom: 12px; padding-left: 12px; align-items: stretch; align-content: flex-start; min-width: 588px; max-width: 588px;">
        <engine:VisualElement name="TopBar" style="flex-grow: 1; height: 60px; flex-direction: row; width: 564px; min-width: auto; max-height: 60px; align-content: flex-start; justify-content: flex-start; align-items: center; padding-top: 8px; padding-right: 8px; padding-bottom: 8px; padding-left: 8px; border-bottom-width: 1px; border-left-color: rgb(48, 48, 48); border-right-color: rgb(48, 48, 48); border-top-color: rgb(48, 48, 48); border-bottom-color: rgb(48, 48, 48);">
            <Unity.AppUI.UI.IconButton name="CloseButton" size="L" icon="x" style="width: 40px; height: 40px;" />
            <Unity.AppUI.UI.Text text="Asset Information" size="XXXL" picking-mode="Ignore" name="Title" style="-unity-text-align: middle-left; height: 40px; max-height: 40px; min-height: 40px; font-size: 18px; color: rgb(255, 255, 255); -unity-text-outline-color: rgb(255, 255, 255); -unity-text-outline-width: 1px; margin-left: 22px; width: 495px; text-overflow: ellipsis; -unity-font-style: normal; white-space: nowrap;">
                <Bindings>
                    <UnityEngine.Localization.LocalizedString property="text" table="GUID:e57257823a7964becb6eb06d6181f15a" entry="Id(113148827787264)" />
                </Bindings>
            </Unity.AppUI.UI.Text>
        </engine:VisualElement>
        <engine:VisualElement name="File" style="flex-grow: 1; width: 564px; justify-content: flex-start; display: flex; margin-top: 18px; flex-direction: row; height: 48px; min-height: 48px; max-height: 48px; padding-left: 16px; padding-right: 16px; margin-bottom: 18px; align-items: center;">
            <engine:VisualElement name="FileIcon" style="flex-grow: 1; background-image: url(&quot;project://database/Assets/Features/Assets/UI/File.png?fileID=2800000&amp;guid=3a7e38d05e15c8c43975d0bbbb2ab267&amp;type=3#File&quot;); width: 32px; height: 32px; min-width: 32px; min-height: 32px; max-width: 32px; max-height: 32px;" />
            <Unity.AppUI.UI.Text size="XXXL" name="FileName" text="File Name" style="-unity-text-align: middle-left; width: 494px; max-width: 494px; min-width: 494px; height: 20px; max-height: 20px; min-height: 20px; font-size: 14px; margin-left: 6px; white-space: nowrap; text-overflow: ellipsis;" />
        </engine:VisualElement>
        <engine:VisualElement name="EditFieldsConainer" style="flex-grow: 1; width: 564px; height: auto; min-height: auto; max-height: none; min-width: 564px; max-width: 564px; padding-top: 16px; padding-right: 16px; padding-bottom: 16px; padding-left: 16px; border-top-width: 1px; border-left-color: rgb(48, 48, 48); border-right-color: rgb(48, 48, 48); border-top-color: rgb(48, 48, 48); border-bottom-color: rgb(48, 48, 48);">
            <engine:VisualElement name="Name" style="flex-grow: 0; flex-direction: row; justify-content: space-between; min-height: 30px; height: 30px; max-height: 30px; max-width: 532px; min-width: 532px; width: 532px; align-items: center;">
                <Unity.AppUI.UI.Text size="XXXL" style="-unity-text-align: middle-left; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; height: 30%; max-height: none; font-size: 14px; width: 100px; max-width: 100px; min-width: 100px; white-space: nowrap; text-overflow: ellipsis;">
                    <Bindings>
