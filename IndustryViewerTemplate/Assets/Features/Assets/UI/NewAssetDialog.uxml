            <engine:VisualElement name="Streaming" style="flex-grow: 0; flex-direction: row; justify-content: flex-start; min-height: 30px; height: 30px; max-height: 30px; max-width: 532px; min-width: 532px; width: 532px; align-items: center; margin-top: 20px;">
                <Unity.AppUI.UI.Checkbox label="    Prepared for 3D Data Streaming" value="Checked" enabled="false" focusable="false" style="margin-left: 12px;">
                    <Bindings>
