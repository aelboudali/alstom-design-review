                <Unity.AppUI.UI.TextField name="AssetNameField" size="L" style="width: 426px; max-width: 426px; min-height: 30px; height: 30%; padding-right: 6px; min-width: 426px; max-height: 30px; margin-left: 6px; color: rgb(255, 255, 255);" />
            </engine:VisualElement>
            <engine:VisualElement name="Type" style="flex-grow: 0; flex-direction: row; justify-content: space-between; margin-top: 16px; height: 30px; max-height: 30px; min-height: 30px; min-width: 532px; width: 532px; max-width: 532px; align-items: center;">
                <Unity.AppUI.UI.Text size="XXXL" style="-unity-text-align: middle-left; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; height: 30%; max-height: none; font-size: 14px; width: 100px; max-width: 100px; min-width: 100px; white-space: nowrap; text-overflow: ellipsis;">
                    <Bindings>
