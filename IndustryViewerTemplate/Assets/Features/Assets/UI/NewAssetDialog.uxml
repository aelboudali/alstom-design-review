                    </Bindings>
                </Unity.AppUI.UI.Checkbox>
                <Unity.AppUI.UI.ActionButton name="3DDSButton" label="3DDS" icon="3dds" focusable="false" style="width: 54px; height: 20px; max-width: 54px; min-width: 54px; max-height: 20px; min-height: 20px; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; background-color: rgba(17, 168, 95, 0.5); border-left-color: rgb(17, 168, 95); border-right-color: rgb(17, 168, 95); border-top-color: rgb(17, 168, 95); border-bottom-color: rgb(17, 168, 95); font-size: 12px; -unity-text-align: middle-right; color: rgb(255, 255, 255); padding-top: 0; padding-right: 3px; padding-bottom: 0; padding-left: 3px; justify-content: flex-end; margin-left: 8px;" />
            </engine:VisualElement>
        </engine:VisualElement>
        <engine:VisualElement name="BottomBar" style="flex-grow: 0; height: 30px; max-height: 30px; min-height: 30px; flex-direction: row; margin-top: 18px; align-items: center; justify-content: flex-end; width: 564px; min-width: 564px; max-width: 564px;">
            <Unity.AppUI.UI.ActionButton name="CancelButton" label="Cancel" style="min-height: 30px; max-height: 30px; width: auto; min-width: 72px; margin-right: 6px; color: rgb(188, 188, 188); white-space: nowrap; text-overflow: ellipsis; max-width: 150px;">
