                    </Bindings>
                </Unity.AppUI.UI.Text>
                <engine:VisualElement name="TagsEditControls" style="flex-grow: 1; margin-top: 0; margin-left: 6px;">
                    <Unity.AppUI.UI.TextField name="TagsTextField" size="L" style="width: 426px; max-width: 426px; min-height: 30px; height: 30%; padding-right: 6px; min-width: 426px; max-height: 30px; margin-left: 0; color: rgb(255, 255, 255);" />
                    <engine:ScrollView name="TagChipsScrollView" mode="Horizontal" style="flex-direction: row; flex-wrap: wrap; max-height: 56px; align-items: flex-start; overflow: hidden; margin-top: 8px; justify-content: space-evenly; align-self: auto; align-content: auto; width: 100%; min-height: 56px;">
                        <engine:Instance template="TagChip" name="TagChip" focusable="true" style="display: flex;" />
                    </engine:ScrollView>
                </engine:VisualElement>
