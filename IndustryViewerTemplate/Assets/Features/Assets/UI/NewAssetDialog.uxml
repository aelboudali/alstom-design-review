                    </Bindings>
                </Unity.AppUI.UI.Text>
                <Unity.AppUI.UI.Chip label="Collection Path" name="CollectionPathChip" deletable="false" style="height: 20px; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; min-height: 20px; max-height: 20px; font-size: 12px; color: rgb(255, 255, 255); margin-left: 6px;" />
            </engine:VisualElement>
            <engine:VisualElement name="Tags" style="flex-grow: 0; flex-direction: row; justify-content: space-between; min-height: auto; height: auto; max-height: none; max-width: 532px; min-width: 532px; width: 532px; align-items: center; margin-top: 16px;">
                <Unity.AppUI.UI.Text size="XXXL" style="-unity-text-align: middle-left; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; height: 30%; max-height: none; font-size: 14px; width: 100px; max-width: 100px; min-width: 100px; white-space: nowrap; text-overflow: ellipsis;">
                    <Bindings>
