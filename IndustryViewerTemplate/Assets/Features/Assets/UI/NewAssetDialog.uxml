            </engine:VisualElement>
            <engine:VisualElement name="Project" style="flex-grow: 0; flex-direction: row; justify-content: flex-start; margin-top: 16px; height: 20px; max-height: 20px; min-height: 20px; min-width: 532px; width: 532px; max-width: 532px; align-items: center;">
                <Unity.AppUI.UI.Text size="XXXL" style="-unity-text-align: middle-left; margin-top: 0; margin-right: 6px; margin-bottom: 0; margin-left: 0; height: 30%; max-height: none; font-size: 14px; width: 100px; max-width: 100px; min-width: 100px; white-space: nowrap; text-overflow: ellipsis;">
