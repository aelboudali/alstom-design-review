                    </Bindings>
                </Unity.AppUI.UI.Text>
                <Unity.AppUI.UI.Dropdown name="AssetTypeDropDown" size="L" default-message="Asset Type" class="AssetDropDownCreation AssetDropDownArrow" style="width: 426px; max-width: 426px; min-height: 30px; max-height: 30px; height: 30px; min-width: 426px; padding-right: 6px; margin-left: 6px; color: rgb(255, 255, 255);">
