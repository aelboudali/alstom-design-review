  - m_Id: 1301378228224
    m_Localized: Merknad
    m_Metadata:
      m_Items: []
  - m_Id: 9757421797892096
    m_Localized: "F\xF8lg tr\xE5d"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421802086400
    m_Localized: "Slutt \xE5 f\xF8lge"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421802086401
    m_Localized: Kopier lenke
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280704
    m_Localized: "Slett tr\xE5d"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280705
    m_Localized: "Er du sikker p\xE5 at du vil slette denne tr\xE5den og alle dens
      svar? Dette kan ikke angres."
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280706
    m_Localized: "Start en ny tr\xE5d..."
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280707
    m_Localized: Velg vedlegg
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280708
    m_Localized: "<color=#0892FF>{reply_count:plural:1\_svar|{}\_svar}</color>"
    m_Metadata:
      m_Items:
      - rid: 8052603406888206663
  - m_Id: 9757421806280709
    m_Localized: Legg til vedlegg
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280710
    m_Localized: Rediger
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280711
    m_Localized: Ukjent bruker
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280714
    m_Localized: '{attachment_count:plural:1 vedlegg|{} vedlegg}'
    m_Metadata:
      m_Items:
      - rid: 8052603406888206663
  - m_Id: 9757421806280715
    m_Localized: "Alle tr\xE5der"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280716
    m_Localized: "Bare \xE5pne tr\xE5der"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280717
    m_Localized: "Legg til et svar i denne tr\xE5den..."
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280718
    m_Localized: "L\xF8st"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280719
    m_Localized: Duplikat filnavn
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280720
    m_Localized: Dette vedlegget er allerede lagt til.
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280721
    m_Localized: Romlig vedlegg
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280722
    m_Localized: Ukjent vedlegg
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280723
    m_Localized: Slett vedlegg
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280724
    m_Localized: "Er du sikker p\xE5 at du vil slette dette vedlegget?"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280725
    m_Localized: Lagre vedlegg
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280726
    m_Localized: "Du er for \xF8yeblikket frakoblet."
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280727
    m_Localized: Du er i gjestemodus.
    m_Metadata:
      m_Items: []
  - m_Id: 9758374261415936
    m_Localized: "<i>har l\xF8st denne tr\xE5den.</i>"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280713
    m_Localized: "<i>har gjen\xE5pnet denne tr\xE5den.</i>"
    m_Metadata:
      m_Items: []
