  m_TableData:
  - m_Id: 1301378228224
    m_Localized: Anteckning
    m_Metadata:
      m_Items: []
  - m_Id: 9757421797892096
    m_Localized: "F\xF6lj tr\xE5d"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421802086400
    m_Localized: "Sluta f\xF6lja tr\xE5d"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421802086401
    m_Localized: "Kopiera l\xE4nk"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280704
    m_Localized: "Ta bort tr\xE5d"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280705
    m_Localized: "\xC4r du s\xE4ker p\xE5 att du vill ta bort den h\xE4r tr\xE5den
      och alla dess svar? Detta kan inte \xE5ngras."
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280706
    m_Localized: "Starta en ny tr\xE5d..."
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280707
    m_Localized: "V\xE4lj bilaga"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280708
    m_Localized: "<color=#0892FF>{reply_count:plural:1\_svar|{}\_svar}</color>"
    m_Metadata:
      m_Items:
      - rid: 8052603406888206664
  - m_Id: 9757421806280709
    m_Localized: "L\xE4gg till bilaga"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280710
    m_Localized: Redigera
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280711
    m_Localized: "Ok\xE4nd anv\xE4ndare"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280714
    m_Localized: "{attachment_count:plural:1\_bilaga|{}\_bilagor}"
    m_Metadata:
      m_Items:
      - rid: 8052603406888206664
  - m_Id: 9757421806280715
    m_Localized: "Alla tr\xE5dar"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280716
    m_Localized: "Endast \xF6ppna tr\xE5dar"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280717
    m_Localized: "L\xE4gg till ett svar i den h\xE4r tr\xE5den..."
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280718
    m_Localized: "L\xF6st"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280719
    m_Localized: Duplicerat filnamn
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280720
    m_Localized: "Den h\xE4r bilagan har redan lagts till."
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280721
    m_Localized: Rumslig bilaga
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280722
    m_Localized: "Ok\xE4nd bilaga"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280723
    m_Localized: Ta bort bilaga
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280724
    m_Localized: "\xC4r du s\xE4ker p\xE5 att du vill ta bort den h\xE4r bilagan?"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280725
    m_Localized: Spara bilaga
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280726
    m_Localized: "Du \xE4r offline just nu."
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280727
    m_Localized: "Du \xE4r i g\xE4stl\xE4ge."
    m_Metadata:
      m_Items: []
  - m_Id: 9758374261415936
    m_Localized: "<i>har l\xF6st den h\xE4r tr\xE5den.</i>"
    m_Metadata:
      m_Items: []
  - m_Id: 9757421806280713
    m_Localized: "<i>har \xE5ter\xF6ppnat den h\xE4r tr\xE5den.</i>"
    m_Metadata:
      m_Items: []
  - m_Id: 9766184659443712
    m_Localized: Svar
    m_Metadata:
      m_Items: []
  - m_Id: 9825352548343808
    m_Localized: Tilbake
    m_Metadata:
      m_Items: []
  - m_Id: 9825352552538112
    m_Localized: Ny kommentar
    m_Metadata:
      m_Items: []
  - m_Id: 9827055381241856
    m_Localized: "Tr\xE5d"
    m_Metadata:
      m_Items: []
