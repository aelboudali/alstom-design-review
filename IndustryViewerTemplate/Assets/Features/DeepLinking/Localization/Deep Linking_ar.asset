  - m_Id: 298597604171776
    m_Localized: "\u062A\u0641\u0639\u064A\u0644 \u0631\u0627\u0628\u0637 \u0627\u0644\u062F\u0639\u0648\u0629"
    m_Metadata:
      m_Items: []
  - m_Id: 299763431940096
    m_Localized: "\u0627\u0644\u062F\u0639\u0648\u0627\u062A \u0645\u062A\u0639\u062F\u062F\u0629
      \u0627\u0644\u0644\u0627\u0639\u0628\u064A\u0646 \u063A\u064A\u0631 \u0645\u062F\u0639\u0648\u0645\u0629
      \u0641\u064A \u0648\u0636\u0639 \u0639\u062F\u0645 \u0627\u0644\u0627\u062A\u0635\u0627\u0644.
      \u064A\u064F\u0631\u062C\u0649 \u0627\u0644\u0639\u0648\u062F\u0629 \u0625\u0644\u0649
      \u0627\u0644\u0648\u0636\u0639 \u0639\u0628\u0631 \u0627\u0644\u0625\u0646\u062A\u0631\u0646\u062A
      \u0625\u0630\u0627 \u0643\u0646\u062A \u0628\u062D\u0627\u062C\u0629 \u0625\u0644\u0649
      \u0628\u062F\u0621 \u062C\u0644\u0633\u0629 \u0645\u062A\u0639\u062F\u062F\u0629
      \u0627\u0644\u0644\u0627\u0639\u0628\u064A\u0646."
    m_Metadata:
      m_Items: []
  - m_Id: 1037017326592000
    m_Localized: "\u062E\u0637\u0623 \u0641\u064A \u0627\u0644\u0648\u0635\u0648\u0644
