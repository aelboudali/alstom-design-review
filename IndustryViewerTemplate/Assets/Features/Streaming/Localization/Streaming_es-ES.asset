    m_Metadata:
      m_Items: []
  - m_Id: 268399140659204
    m_Localized: "Salida de transmisi\xF3n"
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659205
    m_Localized: "\xBFEst\xE1s seguro de salir de la escena del streaming?"
