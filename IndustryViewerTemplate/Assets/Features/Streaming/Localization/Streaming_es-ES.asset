    m_Metadata:
      m_Items: []
  - m_Id: 21710844147523584
    m_Localized: "Este es un recurso referenciado de un dise\xF1o. \xBFEst\xE1 seguro?
      Tenga en cuenta que esta acci\xF3n es irreversible."
    m_Metadata:
      m_Items: []
  - m_Id: 22092926879260672
    m_Localized: "Activo referenciado: {name} tiene una versi\xF3n local {localVersion}
      almacenada en el dispositivo. Sin embargo, el dise\xF1o requiere la versi\xF3n
      {requiredVersion}. \xBFDesea seguir usando la versi\xF3n local?"
    m_Metadata:
      m_Items:
      - rid: 7555826617756942445
