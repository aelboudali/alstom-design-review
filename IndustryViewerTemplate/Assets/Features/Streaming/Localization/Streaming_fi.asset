    - rid: 1545659760810917931
  m_TableData:
  - m_Id: 2543798181888
    m_Localized: Poista omaisuus paikalliselta asemalta
    m_Metadata:
      m_Items: []
  - m_Id: 2720789422080
    m_Localized: "Oletko varma? Huomaa, ett\xE4 t\xE4m\xE4 toiminto on peruuttamaton."
    m_Metadata:
      m_Items: []
  - m_Id: 3004496338944
    m_Localized: "Sis\xE4lt\xF6 poistettu."
    m_Metadata:
      m_Items: []
  - m_Id: 3629921591296
    m_Localized: Lataa omaisuus paikalliselle asemalle
    m_Metadata:
      m_Items: []
  - m_Id: 3705742024704
    m_Localized: "Oletko varma? Huomaa, ett\xE4 lataus voi kest\xE4\xE4 jonkin aikaa
      tiedoston koon vuoksi."
    m_Metadata:
      m_Items: []
  - m_Id: 3894355681280
    m_Localized: Ladataan omaisuutta...
    m_Metadata:
      m_Items: []
  - m_Id: 4142910136320
    m_Localized: Kohteen {name} lataus valmis...
    m_Metadata:
      m_Items:
      - rid: 1545659760810917931
  - m_Id: 5709449125888
    m_Localized: "Stream-l\xE4ge"
    m_Metadata:
      m_Items: []
  - m_Id: 5795449135104
    m_Localized: "V\xE4lj \xF6nskad streamingmetod."
    m_Metadata:
      m_Items: []
  - m_Id: 268399107104768
    m_Localized: '{name} - versio: {num}'
    m_Metadata:
      m_Items:
      - rid: 1545659760810917931
  - m_Id: 268399140659200
    m_Localized: Uusi versio saatavilla
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659201
    m_Localized: Omaisuuden uusi versio on saatavilla. Haluatko vaihtaa uuteen versioon?
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659202
    m_Localized: Kytkin
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659203
    m_Localized: "Hylk\xE4\xE4"
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659204
    m_Localized: Poistu suoratoistosta
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659205
    m_Localized: "Oletko varma, ett\xE4 poistut suoratoistosta?"
    m_Metadata:
      m_Items: []
  - m_Id: 271402836942848
    m_Localized: Uusi Ver. Saatavilla!
    m_Metadata:
      m_Items: []
  - m_Id: 15579884532260864
    m_Localized: Rautalanka
    m_Metadata:
      m_Items: []
  - m_Id: 21644036333887488
    m_Localized: "S\xE4ilytt\xE4\xE4"
    m_Metadata:
      m_Items: []
  - m_Id: 21644036354859008
    m_Localized: "Haluatko s\xE4ilytt\xE4\xE4 viitatut resurssit? T\xE4m\xE4 toimenpide
      on peruuttamaton."
    m_Metadata:
      m_Items: []
  - m_Id: 21710844147523584
    m_Localized: "T\xE4m\xE4 on viitattu sis\xE4lt\xF6 asettelusta. Oletko varma?
      Huomaa, ett\xE4 t\xE4m\xE4 toiminto on peruuttamaton."
    m_Metadata:
      m_Items: []
  - m_Id: 22092926879260672
    m_Localized: "Viitattu sis\xE4lt\xF6 - {name} on laitteelle tallennettu paikallinen
      versio {localVersion}. Asettelu vaatii kuitenkin version {requiredVersion}.
      Haluatko jatkaa paikallisen version k\xE4ytt\xF6\xE4?"
    m_Metadata:
      m_Items:
      - rid: 1545659760810917931
  - m_Id: 40835830153994240
    m_Localized: Valmiina paikalliseen suoratoistoon
    m_Metadata:
      m_Items: []
  - m_Id: 40835830153994241
    m_Localized: "P\xE4ivitys saatavilla paikalliseen suoratoistoon"
    m_Metadata:
      m_Items: []
  - m_Id: 1428897652736
    m_Localized: Organisaatio
    m_Metadata:
      m_Items: []
  - m_Id: 1428897652737
    m_Localized: Projekti
    m_Metadata:
      m_Items: []
  - m_Id: 1428897652738
    m_Localized: Kokoelma
    m_Metadata:
      m_Items: []
  - m_Id: 3862327975936
    m_Localized: Nimi
    m_Metadata:
      m_Items: []
  - m_Id: 40851833860644864
    m_Localized: Omaisuutta ei voi ladata luvan vuoksi
    m_Metadata:
      m_Items: []
  - m_Id: 40851833860644865
    m_Localized: Tallenna asettelu
    m_Metadata:
      m_Items: []
  - m_Id: 40851833860644866
    m_Localized: Tallenna 3D-asettelu Asset Manageriin
    m_Metadata:
      m_Items: []
  - m_Id: 40857613896769536
    m_Localized: "Lis\xE4t\xE4\xE4n {asset}"
    m_Metadata:
      m_Items:
      - rid: 1545659760810917931
  - m_Id: 44808540777340928
    m_Localized: Sinulla ei ole kirjoitusoikeutta.
    m_Metadata:
      m_Items: []
  - m_Id: 45884123531698176
    m_Localized: "Tallennus ep\xE4onnistui, tapahtui tuntematon virhe"
    m_Metadata:
      m_Items: []
  - m_Id: 47728520850300928
    m_Localized: "Linkki kopioitu leikep\xF6yd\xE4lle"
    m_Metadata:
      m_Items: []
  - m_Id: 113671218895249408
    m_Localized: "<b>Det finns inga nedladdade resurser f\xF6r lokal streaming</b>\n\n<size=70%>G\xE5
      online och ladda ner dem innan du forts\xE4tter</size>"
    m_Metadata:
      m_Items: []
  - m_Id: 118748446100283392
    m_Localized: Verktyg
    m_Metadata:
      m_Items: []
  - m_Id: 123180386542936064
    m_Localized: "V\xE4nligen v\xE4lj era organisationer h\xE4r"
    m_Metadata:
      m_Items: []
  - m_Id: 123892356694925312
    m_Localized: "Tillg\xE5ngen har ingen str\xF6mningsbar datam\xE4ngd."
    m_Metadata:
      m_Items: []
  - m_Id: 124618061661593600
    m_Localized: Efterbehandlingsrendering
    m_Metadata:
      m_Items: []
  - m_Id: 124621959373774848
    m_Localized: Tolkning
    m_Metadata:
      m_Items: []
