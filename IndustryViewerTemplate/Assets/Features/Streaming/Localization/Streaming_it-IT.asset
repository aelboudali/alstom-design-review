  m_TableData:
  - m_Id: 2543798181888
    m_Localized: "Rimuovi risorsa dall'unit\xE0 locale"
    m_Metadata:
      m_Items: []
  - m_Id: 2720789422080
    m_Localized: "Sei sicuro? Tieni presente che questa azione \xE8 irreversibile."
    m_Metadata:
      m_Items: []
  - m_Id: 3004496338944
    m_Localized: Risorsa rimossa.
    m_Metadata:
      m_Items: []
  - m_Id: 3629921591296
    m_Localized: "Scarica la risorsa sull'unit\xE0 locale"
    m_Metadata:
      m_Items: []
  - m_Id: 3705742024704
    m_Localized: Sicuro? Tieni presente che il download potrebbe richiedere del tempo
      a causa delle dimensioni del file.
