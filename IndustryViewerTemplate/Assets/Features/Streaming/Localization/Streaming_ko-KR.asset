      m_Items: []
  - m_Id: 268399140659201
    m_Localized: "\uD574\uB2F9 \uC790\uC0B0\uC758 \uC0C8 \uBC84\uC804\uC744 \uC0AC\uC6A9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC0C8 \uBC84\uC804\uC73C\uB85C \uC804\uD658\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
