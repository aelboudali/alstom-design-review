  m_TableData:
  - m_Id: 2543798181888
    m_Localized: Fjern Asset fra lokal stasjon
    m_Metadata:
      m_Items: []
  - m_Id: 2720789422080
    m_Localized: "Er du sikker? V\xE6r oppmerksom p\xE5 at denne handlingen er irreversibel."
    m_Metadata:
      m_Items: []
  - m_Id: 3004496338944
    m_Localized: Aktiva fjernet.
    m_Metadata:
      m_Items: []
  - m_Id: 3629921591296
    m_Localized: Last ned Asset til lokal stasjon
    m_Metadata:
      m_Items: []
  - m_Id: 3705742024704
    m_Localized: "Er du sikker? V\xE6r oppmerksom p\xE5 at nedlastingen kan ta litt
      tid p\xE5 grunn av filst\xF8rrelsen."
    m_Metadata:
      m_Items: []
  - m_Id: 3894355681280
    m_Localized: Laster ned ressurs ...
    m_Metadata:
      m_Items: []
  - m_Id: 4142910136320
    m_Localized: "Fullf\xF8rte nedlastingen av {name}-elementet..."
    m_Metadata:
      m_Items:
      - rid: 1545659760810917932
  - m_Id: 5709449125888
    m_Localized: Suoratoistotila
    m_Metadata:
      m_Items: []
  - m_Id: 5795449135104
    m_Localized: "Valitse haluamasi suoratoistomenetelm\xE4."
    m_Metadata:
      m_Items: []
  - m_Id: 268399107104768
    m_Localized: "{name} \u2013 Versjon: {num}"
    m_Metadata:
      m_Items:
      - rid: 1545659760810917932
  - m_Id: 268399140659200
    m_Localized: Ny versjon tilgjengelig
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659201
    m_Localized: En ny versjon av ressursen er tilgjengelig. Vil du bytte til den
      nye versjonen?
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659202
    m_Localized: Bryter
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659203
    m_Localized: Avskjedige
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659204
    m_Localized: Avslutt streaming
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659205
    m_Localized: "Er du sikker p\xE5 at du vil avslutte streaming-scenen?"
    m_Metadata:
      m_Items: []
  - m_Id: 271402836942848
    m_Localized: Ny Ver. Tilgjengelig!
    m_Metadata:
      m_Items: []
  - m_Id: 15579884532260864
    m_Localized: Wireframe
    m_Metadata:
      m_Items: []
  - m_Id: 21644036333887488
    m_Localized: Bevare
    m_Metadata:
      m_Items: []
  - m_Id: 21644036354859008
    m_Localized: Vil du beholde refererte eiendeler? Denne handlingen er irreversibel.
    m_Metadata:
      m_Items: []
  - m_Id: 21710844147523584
    m_Localized: "Dette er en referert ressurs fra en layout. Er du sikker? V\xE6r
      oppmerksom p\xE5 at denne handlingen er irreversibel."
    m_Metadata:
      m_Items: []
  - m_Id: 22092926879260672
    m_Localized: "Referert ressurs \u2013 {name} har en lokal versjon {localVersion}
      lagret p\xE5 enheten. Men oppsettet krever versjon {requiredVersion}. Vil du
      fortsette \xE5 bruke den lokale versjonen?"
    m_Metadata:
      m_Items:
      - rid: 1545659760810917932
  - m_Id: 40835830153994240
    m_Localized: Klar for lokal streaming
    m_Metadata:
      m_Items: []
  - m_Id: 40835830153994241
    m_Localized: "Oppdatering tilgjengelig for lokal str\xF8mming"
    m_Metadata:
      m_Items: []
  - m_Id: 1428897652736
    m_Localized: Organisasjon
    m_Metadata:
      m_Items: []
  - m_Id: 1428897652737
    m_Localized: Prosjekt
    m_Metadata:
      m_Items: []
  - m_Id: 1428897652738
    m_Localized: Samling
    m_Metadata:
      m_Items: []
  - m_Id: 3862327975936
    m_Localized: Navn
    m_Metadata:
      m_Items: []
  - m_Id: 40851833860644864
    m_Localized: "Kan ikke laste inn en ressurs p\xE5 grunn av tillatelse"
    m_Metadata:
      m_Items: []
  - m_Id: 40851833860644865
    m_Localized: Lagre layout
    m_Metadata:
      m_Items: []
  - m_Id: 40851833860644866
    m_Localized: Lagre 3D-oppsettet ditt i Asset Manager
    m_Metadata:
      m_Items: []
  - m_Id: 40857613896769536
    m_Localized: Legger til {asset}
    m_Metadata:
      m_Items:
      - rid: 1545659760810917932
  - m_Id: 44808540777340928
    m_Localized: Du har ikke skrivetillatelse.
    m_Metadata:
      m_Items: []
  - m_Id: 45884123531698176
    m_Localized: Lagring mislyktes, det oppstod en ukjent feil
    m_Metadata:
      m_Items: []
  - m_Id: 47728520850300928
    m_Localized: Kopierte lenken til utklippstavlen
    m_Metadata:
      m_Items: []
  - m_Id: 113671218895249408
    m_Localized: '<b>Paikallista suoratoistoa varten ei ole ladattuja materiaaleja</b>


      <size=70%>Lataa
      ne verkossa ennen kuin jatkat</size>'
    m_Metadata:
      m_Items: []
  - m_Id: 118748446100283392
    m_Localized: "Ty\xF6kalu"
    m_Metadata:
      m_Items: []
  - m_Id: 123180386542936064
    m_Localized: "Valitse organisaatiosi t\xE4st\xE4"
    m_Metadata:
      m_Items: []
  - m_Id: 123892356694925312
    m_Localized: Resurssilla ei ole suoratoistettavaa tietojoukkoa.
    m_Metadata:
      m_Items: []
  - m_Id: 124618061661593600
    m_Localized: "J\xE4lkik\xE4sittelyrender\xF6inti"
    m_Metadata:
