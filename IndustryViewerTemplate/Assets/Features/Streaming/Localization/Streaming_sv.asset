  m_TableData:
  - m_Id: 2543798181888
    m_Localized: "Ta bort tillg\xE5ng fr\xE5n lokal enhet"
    m_Metadata:
      m_Items: []
  - m_Id: 2720789422080
    m_Localized: "\xC4r du s\xE4ker? Observera att denna \xE5tg\xE4rd \xE4r o\xE5terkallelig."
    m_Metadata:
      m_Items: []
  - m_Id: 3004496338944
    m_Localized: "Tillg\xE5ng borttagen."
    m_Metadata:
      m_Items: []
  - m_Id: 3629921591296
    m_Localized: Ladda ner Asset till lokal enhet
    m_Metadata:
      m_Items: []
  - m_Id: 3705742024704
    m_Localized: "\xC4r du s\xE4ker? Observera att nedladdningen kan ta lite tid
      p\xE5 grund av filstorleken."
    m_Metadata:
      m_Items: []
  - m_Id: 3894355681280
    m_Localized: "Laddar ned tillg\xE5ng..."
    m_Metadata:
      m_Items: []
  - m_Id: 4142910136320
    m_Localized: "Nedladdningen av {name}-tillg\xE5ngen \xE4r klar..."
    m_Metadata:
      m_Items:
      - rid: 1545659760810917933
  - m_Id: 5709449125888
    m_Localized: "Str\xF8mmemodus"
    m_Metadata:
      m_Items: []
  - m_Id: 5795449135104
    m_Localized: "Vennligst velg foretrukket str\xF8mmemetode."
    m_Metadata:
      m_Items: []
  - m_Id: 268399107104768
    m_Localized: '{name} - Version: {num}'
    m_Metadata:
      m_Items:
      - rid: 1545659760810917933
  - m_Id: 268399140659200
    m_Localized: "Ny version tillg\xE4nglig"
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659201
    m_Localized: "En ny version av tillg\xE5ngen \xE4r tillg\xE4nglig. Vill du byta
      till den nya versionen?"
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659202
    m_Localized: "V\xE4xla"
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659203
    m_Localized: "Avf\xE4rda"
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659204
    m_Localized: Avsluta streaming
    m_Metadata:
      m_Items: []
  - m_Id: 268399140659205
    m_Localized: "\xC4r du s\xE4ker p\xE5 att du l\xE4mnar streamingscenen?"
    m_Metadata:
      m_Items: []
  - m_Id: 271402836942848
    m_Localized: "Ny Ver. Tillg\xE4nglig!"
    m_Metadata:
      m_Items: []
  - m_Id: 15579884532260864
    m_Localized: "Tr\xE5dram"
    m_Metadata:
      m_Items: []
  - m_Id: 21644036333887488
    m_Localized: Bevara
    m_Metadata:
      m_Items: []
  - m_Id: 21644036354859008
    m_Localized: "Vill du bevara refererade tillg\xE5ngar? Denna \xE5tg\xE4rd \xE4r
      o\xE5terkallelig."
    m_Metadata:
      m_Items: []
  - m_Id: 21710844147523584
    m_Localized: "Det h\xE4r \xE4r en tillg\xE5ng som refereras fr\xE5n en layout.
      \xC4r du s\xE4ker? Observera att denna \xE5tg\xE4rd \xE4r o\xE5terkallelig."
    m_Metadata:
      m_Items: []
  - m_Id: 22092926879260672
    m_Localized: "Refererad tillg\xE5ng \u2013 {name} har en lokal version {localVersion}
      lagrad p\xE5 enheten. Men layouten kr\xE4ver version {requiredVersion}. Vill
      du forts\xE4tta anv\xE4nda den lokala versionen?"
    m_Metadata:
      m_Items:
      - rid: 1545659760810917933
  - m_Id: 40835830153994240
    m_Localized: "Redo f\xF6r lokal streaming"
    m_Metadata:
      m_Items: []
  - m_Id: 40835830153994241
    m_Localized: "Uppdatering tillg\xE4nglig f\xF6r lokal streaming"
    m_Metadata:
      m_Items: []
  - m_Id: 1428897652736
    m_Localized: Organisation
    m_Metadata:
      m_Items: []
  - m_Id: 1428897652737
    m_Localized: Projekt
    m_Metadata:
      m_Items: []
  - m_Id: 1428897652738
    m_Localized: Samling
    m_Metadata:
      m_Items: []
  - m_Id: 3862327975936
    m_Localized: Namn
    m_Metadata:
      m_Items: []
  - m_Id: 40851833860644864
    m_Localized: "Det gick inte att ladda en tillg\xE5ng p\xE5 grund av beh\xF6righet"
    m_Metadata:
      m_Items: []
  - m_Id: 40851833860644865
    m_Localized: Spara layout
    m_Metadata:
      m_Items: []
  - m_Id: 40851833860644866
    m_Localized: Spara din 3D-layout i Asset Manager
    m_Metadata:
      m_Items: []
  - m_Id: 40857613896769536
    m_Localized: "L\xE4gger till {asset}"
    m_Metadata:
      m_Items:
      - rid: 1545659760810917933
  - m_Id: 44808540777340928
    m_Localized: "Du har inte skrivbeh\xF6righet."
    m_Metadata:
      m_Items: []
  - m_Id: 45884123531698176
    m_Localized: "Det gick inte att spara, ett ok\xE4nt fel uppstod"
    m_Metadata:
      m_Items: []
  - m_Id: 47728520850300928
    m_Localized: "Kopierade l\xE4nken till urklipp"
    m_Metadata:
      m_Items: []
  - m_Id: 113671218895249408
    m_Localized: "<b>Det finnes ingen nedlastede ressurser for lokal str\xF8mming</b>\n\n<size=70%>G\xE5
      p\xE5 nett og last dem ned f\xF8r du fortsetter</size>"
    m_Metadata:
      m_Items: []
  - m_Id: 118748446100283392
    m_Localized: "Verkt\xF8y"
    m_Metadata:
      m_Items: []
  - m_Id: 123180386542936064
    m_Localized: Vennligst velg organisasjonene dine her
    m_Metadata:
      m_Items: []
  - m_Id: 123892356694925312
    m_Localized: "Ressursen har ikke et str\xF8mmebart datasett."
    m_Metadata:
      m_Items: []
  - m_Id: 124618061661593600
    m_Localized: Etterbehandling av rendering
    m_Metadata:
      m_Items: []
  - m_Id: 124621959373774848
    m_Localized: Gjengivelse
    m_Metadata:
      m_Items: []
