                </Bindings>
            </Unity.AppUI.UI.Text>
            <Unity.AppUI.UI.Checkbox name="FPSToggle" emphasized="true" />
        </engine:VisualElement>
        <engine:VisualElement style="flex-grow: 0; flex-direction: row; height: 40px; display: flex; align-items: center; margin-bottom: 8px;">
            <Unity.AppUI.UI.Text text="Language" style="width: 200px; margin-right: 32px;">
